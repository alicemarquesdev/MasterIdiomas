@model UsuarioModel
@{
    Layout = "_LayoutDeslogado";
    ViewData["Title"] = "Criar Conta";
}

<body class="bg-gradient-primary">
    <div class="container">
        <div class="card o-hidden border-0 shadow-lg my-5">
            <div class="card-body p-0">
                <div class="row">
                    <div class="col-lg-5 d-none d-lg-block bg-login-image d-flex justify-content-center align-items-center">
                        <img src="~/img/image-login.jpg" class="img-fluid" />
                    </div>
                    <div class="col-lg-7">
                        <div class="p-5">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-4">Criar conta!</h1>
                            </div>
                            <form class="user" asp-controller="Login" asp-action="CriarConta" method="post">
                                <div class="form-group">
                                    <input type="text" class="form-control form-control-user" asp-for="Nome" placeholder="Nome">
                                    <span class="text-danger">@Html.ValidationMessageFor(x => x.Nome)</span>
                                </div>
                                <div class="form-group">
                                    <input type="email" class="form-control form-control-user" asp-for="Email" placeholder="Email">
                                    <span class="text-danger">@Html.ValidationMessageFor(x => x.Email)</span>
                                </div>
                                <div class="form-group">
                                    <input type="password" class="form-control form-control-user" asp-for="Senha" placeholder="Senha">
                                    <span class="text-danger">@Html.ValidationMessageFor(x => x.Senha)</span>
                                    <small class="form-text text-muted mt-2">
                                        A senha deve ter pelo menos 8 caracteres, incluindo:
                                        <ul>
                                            <li>1 letra maiúscula</li>
                                            <li>1 letra minúscula</li>
                                            <li>1 número</li>
                                            <li>1 caractere especial (como &commat;, $, !, etc.)</li>
                                        </ul>
                                    </small>
                                </div>
                                <button type="submit" class="btn btn-primary btn-user btn-block">Criar Conta</button>
                            </form>
                            <hr>
                            <div class="text-center">
                                <a class="small" asp-controller="Login" asp-action="RedefinirSenha">Esqueceu a senha?</a>
                            </div>
                            <div class="text-center">
                                <a class="small" asp-controller="Login" asp-action="Index">Já tem uma conta? Faça login!</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

