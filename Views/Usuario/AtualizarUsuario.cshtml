@model UsuarioModel
@{
    ViewData["Title"] = "Editar Dados";
}


<div class="container-fluid px-4">
    <h1 class="mt-4">Editar Dados</h1>
    
    <div class="container justify-content-end">
        <a class="btn btn-danger w-25 " asp-controller="Usuario" asp-action="AlterarSenha" role="button">Alterar Senha</a>
    </div>

    <form asp-controller="Usuario" asp-action="AtualizarUsuario" method="post">

        <!-- Campo oculto para o Id -->
        <input type="hidden" asp-for="UsuarioId" />

        <!-- Nome -->
        <div class="mb-3">
            <label for="Nome" class="form-label">Nome</label>
            <input type="text" class="form-control" asp-for="Nome">
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Nome)
            </span>
        </div>

        <!-- Email -->
        <div class="mb-3">
            <label for="Email" class="form-label">Email</label>
            <input type="email" class="form-control" asp-for="Email" maxlength="100">
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Email)
            </span>
        </div>

        <!-- Botões -->
        <button type="submit" class="btn btn-primary w-100 mb-1">Atualizar Dados</button>
        <a class="btn btn-secondary d-block" asp-controller="Home" asp-action="Index" role="button">Voltar</a>
    </form>
</div>