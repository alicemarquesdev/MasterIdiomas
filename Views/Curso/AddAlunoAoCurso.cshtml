@model List<AlunoModel>

@{
    ViewData["Title"] = "Adicionar Aluno Ao Curso";
}

<div class="container-fluid px-4">
    <ol class="breadcrumb mt-1 bg-transparent">
        <li class="breadcrumb-item">
            <a asp-controller="Curso" asp-action="Index" class="text-decoration-none">Cursos</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Curso" asp-action="AlunosDoCurso" asp-route-CursoId="@ViewBag.CursoId" class="text-decoration-none">Alunos do Curso</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Adicionar Aluno Ao Curso</li>
    </ol>

    <h1 class="mt-2 mb-4">Adicionar Aluno Ao Curso</h1>

    <div class="card mb-3">
        <div class="card-body">
            Lista de alunos não inscritos no curso, disponíveis para serem adicionada ao curso.
        </div>
    </div>

    <div class="card shadow mb-4 mt-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Lista de Alunos Não Inscritos</h6>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered text-center" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Data Nascimento</th>
                            <th>Gênero</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var aluno in Model)
                            {
                                <tr>
                                    <td>@aluno.Nome</td>
                                    <td>@aluno.DataNascimento.ToString("dd/MM/yyyy")</td>
                                    <td>@aluno.Genero</td>
                                    <td>@aluno.Status</td>
                                    <td>
                                        <form asp-controller="AlunoCurso" asp-action="AddAlunoAoCurso" method="post">
                                            <input type="hidden" name="CursoId" value="@ViewBag.CursoId" />
                                            <input type="hidden" name="AlunoId" value="@aluno.AlunoId" />
                                            <button type="submit" class="btn-sm btn-primary">Adicionar Aluno Ao Curso</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center">Nenhum aluno encontrado.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
