@model List<CursoModel>
@{
    ViewData["Title"] = "Cursos";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Cursos</h1>

    <!-- Card com Lista de Cursos -->
    <div class="card shadow mb-4 mt-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Lista Geral de Cursos</h6>
            <a class="btn btn-primary" asp-controller="Curso" asp-action="AddCurso">Criar um curso</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered text-center" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Curso</th>
                            <th>Turno</th>
                            <th>Nível</th>
                            <th>Data de Início</th>
                            <th>Máx. Alunos</th>
                            <th>Status</th>
                            <th>Professor</th>
                            <th>Alunos</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var curso in Model)
                            {
                                <tr>
                                    <td>@curso.Idioma</td>
                                    <td>@curso.Turno</td>
                                    <td>@curso.Nivel</td>
                                    <td>@curso.DataInicio.ToString("dd/MM/yyyy")</td>
                                    <td>@curso.MaxAlunos</td>
                                    <td>@curso.Status</td>
                                    <td>
                                        @if (curso.Professor != null)
                                        {
                                            @curso.Professor.Nome
                                        }
                                        else
                                        {
                                            <a class="btn-sm btn-primary text-decoration-none d-block" asp-route-Id="@curso.CursoId" asp-controller="Curso" asp-action="AddProfessorAoCurso">Adicionar</a>
                                        }
                                    </td>
                                    <td>
                                        <a class="btn-sm btn-primary text-decoration-none" asp-route-CursoId="@curso.CursoId" asp-controller="Curso" asp-action="AlunosDoCurso">Alunos</a>
                                    </td>
                                    <td class="text-center">
                                        <a class="btn-sm btn-primary text-decoration-none" asp-route-Id="@curso.CursoId" asp-controller="Curso" asp-action="AtualizarCurso"><i class="far fa-edit"></i></a>
                                        <a class="btn-sm btn-danger text-decoration-none" asp-route-Id="@curso.CursoId" asp-controller="Curso" asp-action="RemoverCurso"><i class="far fa-trash-alt"></i></a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-3">Nenhum curso encontrado.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
