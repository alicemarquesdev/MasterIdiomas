@using MasterIdiomas.Enums
@model CursoModel
@{
    ViewData["Title"] = "Editar Dados - Curso";
    var idiomas = ViewBag.Idiomas as List<string>;
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Editar Dados - Curso</h1>
    
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-primary d-flex align-items-center" role="alert">
            <div>
                @TempData["MensagemSucesso"]
            </div>

            <button type="button" class="btn btn-primary btn-sm close-alert ms-auto" data-bs-dismiss="alert" aria-label="Close">X</button>

        </div>
    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <div>
                @TempData["MensagemErro"]
            </div>
            <button type="button" class="btn btn-danger btn-sm close-alert ms-auto" data-bs-dismiss="alert" aria-label="Close">X</button>

        </div>
    }

    <form asp-controller="Curso" asp-action="AtualizarCurso" method="post">

        <input type="hidden" asp-for="CursoId" />
        <input type="hidden" asp-for="ProfessorId" />

        <!-- Idioma -->
        <div class="mb-3">
            <label for="Idioma" class="form-label">Idioma</label>
            <select class="form-control" asp-for="Idioma">
                @if (ViewBag.Idiomas != null)
                {
                    foreach (var idioma in ViewBag.Idiomas)
                    {
                        <option value="@idioma">@idioma</option>
                    }
                }

            </select>
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Idioma)
            </span>
        </div>

        <!-- Turno -->
        <div class="mb-3">
            <label for="Turno" class="form-label">Turno</label>
            <select class="form-control" asp-for="Turno">
                <option value="" selected>Selecione</option>
                <option value="Manhã">Manhã</option>
                <option value="Tarde">Tarde</option>
                <option value="Noite">Noite</option>
            </select>
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Turno)
            </span>
        </div>

        <!-- Nível -->
        <div class="mb-3">
            <label for="Nivel" class="form-label">Nivel</label>
            <select class="form-control" asp-for="Nivel">
                <option value="" selected>Selecione</option>
                <option value="Iniciante">Iniciante</option>
                <option value="Intermediário">Intermediário</option>
                <option value="Avançado">Avançado</option>
            </select>
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Nivel)
            </span>
        </div>

        <!-- Data de Inicio -->
        <div class="mb-3">
            <label for="DataInicio" class="form-label">Data de Início</label>
            <input type="date" class="form-control" asp-for="DataInicio" min="@DateTime.Now" max="2025-10-10">
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.DataInicio)
            </span>
        </div>

        <!-- Carga Horária -->
        <div class="mb-3">
            <label for="CargaHoraria" class="form-label">Carga Horária (Horas de curso)</label>
            <input type="number" class="form-control" asp-for="CargaHoraria" min="10" max="50">
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.CargaHoraria)
            </span>
        </div>

        <!-- Maxima Quantidade de Alunos -->
        <div class="mb-3">
            <label for="MaxAlunos" class="form-label">Quantidade Máxima de Alunos</label>
            <input type="number" class="form-control" asp-for="MaxAlunos" min="10" max="30">
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.MaxAlunos)
            </span>
        </div>

        <!-- Status -->
        <div class="mb-3">
            <label for="Status" class="form-label">Status</label>
            <select class="form-control" asp-for="Status">
                <option value="@StatusCursoEnum.EmAndamento" selected>@StatusCursoEnum.EmAndamento</option>
                <option value="@StatusCursoEnum.Concluído">@StatusCursoEnum.Concluído</option>
                <option value="@StatusCursoEnum.Cancelado">@StatusCursoEnum.Cancelado</option>
            </select>
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Status)
            </span>
        </div>


        <!-- Botões -->
        <button type="submit" class="btn btn-primary w-100 mb-1">Editar Curso</button>
        <a class="btn btn-secondary d-block" asp-action="Index" asp-controller="Curso" role="button">Voltar</a>
    </form>
</div>
