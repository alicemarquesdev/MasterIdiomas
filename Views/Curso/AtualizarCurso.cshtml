@using MasterIdiomas.Enums
@model CursoModel
@{
    ViewData["Title"] = "Editar Dados - Curso";
    var idiomas = ViewBag.Idiomas as List<string>;
}

<div class="container-fluid px-4">
    <ol class="breadcrumb mt-1 bg-transparent">
        <li class="breadcrumb-item">
            <a asp-controller="Curso" asp-action="Index" class="text-decoration-none">Cursos</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Editar Dados</li>
    </ol>

    <h1 class="mt-2 mb-4">Editar Dados - Curso</h1>

    <form asp-controller="Curso" asp-action="AtualizarCurso" method="post">
        <input type="hidden" asp-for="CursoId" />

        <div class="row">
            <!-- Idioma -->
            <div class="mb-3 col-md-6">
                <label for="Idioma" class="form-label">Idioma</label>
                <select class="form-control" asp-for="Idioma" required>
                    <option value="" selected>Selecione</option>
                    @if (idiomas != null)
                    {
                        foreach (var idioma in idiomas)
                        {
                            <option value="@idioma">@idioma</option>
                        }
                    }
                </select>
                <span class="text-danger">@Html.ValidationMessageFor(x => x.Idioma)</span>
            </div>

            <!-- Turno -->
            <div class="mb-3 col-md-6">
                <label for="Turno" class="form-label">Turno</label>
                <select class="form-control" asp-for="Turno" required>
                    <option value="" selected>Selecione</option>
                    <option value="Manhã">Manhã</option>
                    <option value="Tarde">Tarde</option>
                    <option value="Noite">Noite</option>
                </select>
                <span class="text-danger">@Html.ValidationMessageFor(x => x.Turno)</span>
            </div>
        </div>

        <div class="row">
            <!-- Nível -->
            <div class="mb-3 col-md-6">
                <label for="Nivel" class="form-label">Nível</label>
                <select class="form-control" asp-for="Nivel" required>
                    <option value="" selected>Selecione</option>
                    <option value="Iniciante">Iniciante</option>
                    <option value="Intermediário">Intermediário</option>
                    <option value="Avançado">Avançado</option>
                </select>
                <span class="text-danger">@Html.ValidationMessageFor(x => x.Nivel)</span>
            </div>

            <!-- Data de Início -->
            <div class="mb-3 col-md-6">
                <label for="DataInicio" class="form-label">Data de Início</label>
                <input type="date" class="form-control" asp-for="DataInicio" min="@DateTime.Now.AddYears(-1)" required>
                <span class="text-danger">@Html.ValidationMessageFor(x => x.DataInicio)</span>
            </div>
        </div>

        <div class="row">
            <!-- Carga Horária -->
            <div class="mb-3 col-md-6">
                <label for="CargaHoraria" class="form-label">Carga Horária</label>
                <input type="number" class="form-control" asp-for="CargaHoraria" placeholder="Horas de curso." min="10" max="50" required>
                <span class="text-danger">@Html.ValidationMessageFor(x => x.CargaHoraria)</span>
            </div>

            <!-- Quantidade Máxima de Alunos -->
            <div class="mb-3 col-md-6">
                <label for="MaxAlunos" class="form-label">Quantidade Máxima de Alunos</label>
                <input type="number" class="form-control" asp-for="MaxAlunos" min="10" max="30" required>
                <span class="text-danger">@Html.ValidationMessageFor(x => x.MaxAlunos)</span>
            </div>
        </div>

        <!-- Status -->
        <div class="mb-3">
            <label for="Status" class="form-label">Status</label>
            <select class="form-control" asp-for="Status">
                <option value="@StatusCursoEnum.EmAndamento" selected>@StatusCursoEnum.EmAndamento</option>
                <option value="@StatusCursoEnum.Concluído">@StatusCursoEnum.Concluído</option>
                <option value="@StatusCursoEnum.Cancelado">@StatusCursoEnum.Cancelado</option>
            </select>
            <div class="text-danger">
                <strong>Atenção:</strong> Se o status do curso for atualizado para cancelado, os alunos serão removidos do curso.
            </div>
            <span class="text-danger">@Html.ValidationMessageFor(x => x.Status)</span>
        </div>

        <!-- Botões -->
        <button type="submit" class="btn btn-primary w-100 mb-1">Editar Curso</button>
        <a class="btn btn-secondary d-block mb-1" asp-controller="Curso" asp-action="Index" role="button">Voltar</a>
    </form>

    <hr class="my-4">

    @if (Model.ProfessorId != null)
    {
        <h3 class="mt-4 mb-4">Professor</h3>
        <a class="btn btn-primary d-block mb-1" asp-controller="Professor" asp-action="AtualizarProfessor" asp-route-Id="@Model.ProfessorId" role="button">Atualizar Dados do Professor</a>

        <form asp-controller="Professor" asp-action="RemoverProfessorDoCurso" method="post">
            <input type="hidden" name="professorId" value="@Model.ProfessorId" />
            <input type="hidden" name="cursoId" value="@Model.CursoId" />
            <button type="submit" class="btn btn-danger w-100">Remover Professor</button>
        </form>
    }
</div>
