@model List<AlunoModel> // Certifique-se de que o namespace está correto

@{
    ViewData["Title"] = "Alunos - " + ViewBag.IdiomaSelecionado;
}

<div class="container-fluid px-4">
    <!-- Breadcrumb -->
    <ol class="breadcrumb mt-1 bg-transparent">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Visão Geral</a></li>
        <li class="breadcrumb-item active" aria-current="page">@ViewBag.IdiomaSelecionado</li>
    </ol>

    <h1 class="mt-2 mb-4">@ViewBag.IdiomaSelecionado</h1>

    <!-- Card de introdução -->
    <div class="card mb-3">
        <div class="card-body">
            A seguir, apresentamos a lista de alunos que participam do curso de @ViewBag.IdiomaSelecionado.
        </div>
    </div>

    <!-- Lista de Alunos -->
    <div class="card shadow mb-4 mt-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Lista Geral de Alunos - @ViewBag.IdiomaSelecionado</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered text-center" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Data de Nascimento</th>
                            <th>Gênero</th>
                            <th>Status</th>
                            <th>Turno</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var aluno in Model)
                            {
                                <tr>
                                    <td>@aluno.Nome</td>
                                    <td>@aluno.DataNascimento.ToString("dd/MM/yyyy")</td>
                                    <td>@aluno.Genero</td>
                                    <td>@aluno.Status</td>
                                    <td>@ViewBag.TurnoDoCurso</td>
                                    <td>
                                        <a class="btn-sm btn-primary text-decoration-none"
                                           asp-route-Id="@aluno.AlunoId"
                                           asp-controller="Aluno"
                                           asp-action="AtualizarAlunoAsync">Editar</a>
                                        <a class="btn-sm btn-danger text-decoration-none"
                                           asp-route-Id="@aluno.AlunoId"
                                           asp-controller="Aluno"
                                           asp-action="RemoverAluno">Remover</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-3">Nenhum aluno encontrado.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
