@using MasterIdiomas.Enums
@model ProfessorModel
@{
    ViewData["Title"] = "Editar Dados - Professor";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Editar Dados - Professor</h1>

    <form asp-controller="Professor" asp-action="AtualizarProfessor" method="post">

        <!-- ID -->
        <input type="hidden" asp-for="ProfessorId" />


        <!-- Carga Horária -->
        <div class="mb-3">
            <label for="Nome" class="form-label">Nome</label>
            <input type="text" class="form-control" asp-for="Nome" maxlength="100">
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Nome)
            </span>
        </div>

        <div class="mb-3">
            <label for="Email" class="form-label">Email</label>
            <input type="email" class="form-control" asp-for="Email" maxlength="100">
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Email)
            </span>
        </div>

        <div class="mb-3">
            <label for="DataNascimento" class="form-label">Data de Nascimento</label>
            <input type="date" class="form-control" asp-for="DataNascimento" min="1940-10-10" max="2010-10-10">
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.DataNascimento)
            </span>
        </div>

        <div class="mb-3">
            <label for="Genero" class="form-label">Gênero</label>
            <select class="form-control" asp-for="Genero">
                <option value="" selected>Selecione</option>
                <option value="Feminino">Feminino</option>
                <option value="Masculino">Masculino</option>
                <option value="Outro">Outro</option>
            </select>
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Genero)
            </span>
        </div>


        <div class="mb-3">
            <label for="Status" class="form-label">Status</label>
            <select class="form-control" asp-for="Status">
                <option value="@StatusEnum.Ativo" selected>Ativo</option>
                <option value="@StatusEnum.Inativo">Inativo</option>
            </select>
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Status)
            </span>
        </div>

        <!-- Botões -->
        <button type="submit" class="btn btn-primary w-100 mb-1">Editar Professor</button>
        <a class="btn btn-secondary d-block" asp-action="Index" asp-controller="Professor" role="button">Voltar</a>
    </form>
</div>
