@model List<CursoModel>
@{
    ViewData["Title"] = "Cursos - Professor";
}

<div class="container-fluid px-4">
    <h1 class="mt-4 mb-4">Cursos - Professor</h1>


    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-primary d-flex align-items-center" role="alert">
            <div>
                @TempData["MensagemSucesso"]
            </div>

            <button type="button" class="btn btn-primary btn-sm close-alert ms-auto" data-bs-dismiss="alert" aria-label="Close">X</button>

        </div>
    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <div>
                @TempData["MensagemErro"]
            </div>
            <button type="button" class="btn btn-danger btn-sm close-alert ms-auto" data-bs-dismiss="alert" aria-label="Close">X</button>

        </div>
    }

    <div class="card mb-3">
        <div class="card-body">
            Visualize e edite os cursos dos quais o professor lesiona.
        </div>
    </div>

    <div class="card shadow mb-4 mt-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">
                Lista de Cursos
            </h6>
            <a class="btn btn-primary" asp-controller="Curso" asp-action="AddCurso">Criar Curso e Professor</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Curso</th>
                            <th>Turno</th>
                            <th>Nível</th>
                            <th>Data de Início</th>
                            <th>Status</th>
                            <th>Professor</th>
                            <th>#</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var curso in Model)
                            {
                                <tr>
                                    <td>@curso.Idioma</td>
                                    <td>@curso.Turno</td>
                                    <td>@curso.Nivel</td>
                                    <td>@curso.DataInicio.ToString("dd/MM/yyyy")</td>
                                    <td>@curso.Status</td>
                                    <td>@curso.Professor.Nome</td>
                                    <td>
                                        <a class="btn-sm btn-primary text-decoration-none d-block text-center" asp-route-Id="@curso.CursoId" asp-controller="Curso" asp-action="AtualizarCurso">Editar</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>