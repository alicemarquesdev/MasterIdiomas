@using MasterIdiomas.Enums
@model ProfessorModel
@{
    ViewData["Title"] = "Adicionar Professor";
}

<div class="container-fluid px-4">
    <ol class="breadcrumb mt-1 bg-transparent">
        <li class="breadcrumb-item">
            <a asp-controller="Professor" asp-action="Index" class="text-decoration-none">Professores</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Adicionar Professor</li>
    </ol>

    <h1 class="mt-2 mb-4">Adicionar Professor</h1>

    <form asp-controller="Professor" asp-action="AddProfessor" method="post">

        <!-- Nome Professor -->
        <div class="mb-3">
            <label for="Nome" class="form-label">Nome</label>
            <input type="text" class="form-control" asp-for="Nome" maxlength="100" placeholder="Digite o nome do professor.">
            <span class="text-danger">@Html.ValidationMessageFor(x => x.Nome)</span>
        </div>

        <!-- Email Professor -->
        <div class="mb-3">
            <label for="Email" class="form-label">Email</label>
            <input type="email" class="form-control" asp-for="Email" maxlength="100" placeholder="Digite o email do professor.">
            <span class="text-danger">@Html.ValidationMessageFor(x => x.Email)</span>
        </div>

        <!-- Data de Nascimento -->
        <div class="mb-3">
            <label for="DataNascimento" class="form-label">Data de Nascimento</label>
            <input type="date" class="form-control" asp-for="DataNascimento" min="1940-10-10" max="2010-10-10">
            <span class="text-danger">@Html.ValidationMessageFor(x => x.DataNascimento)</span>
        </div>

        <div class="mb-3">
            <label for="Genero" class="form-label">Gênero</label>
            <select class="form-control" asp-for="Genero">
                <option value="" selected>Selecione</option>
                <option value="@GeneroEnum.Feminino">@GeneroEnum.Feminino</option>
                <option value="@GeneroEnum.Masculino">@GeneroEnum.Masculino</option>
                <option value="@GeneroEnum.Outro">@GeneroEnum.Outro</option>
            </select>
            <span class="text-danger">@Html.ValidationMessageFor(x => x.Genero)</span>
        </div>


        <!-- Botões -->
        <button type="submit" class="btn btn-primary w-100 mb-2">Adicionar Professor</button>
        <a class="btn btn-secondary d-block" asp-action="Index" asp-controller="Professor" role="button">Voltar</a>
    </form>
</div>
