@using MasterIdiomas.Enums
@model List<CursoModel>

@{
    ViewData["Title"] = "Cursos Disponíveis";
}

<div class="container-fluid px-4">
    <ol class="breadcrumb mt-1 bg-transparent">
        <li class="breadcrumb-item">
            <a asp-controller="Aluno" asp-action="Index" class="text-decoration-none">Alunos</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Cursos Disponíveis</li>
    </ol>

    <h1 class="mt-2 mb-4">Cursos Disponíveis</h1>

    <div class="card mb-3">
        <div class="card-body">
            Lista completa de cursos disponíveis para o aluno se inscrever e iniciar novos aprendizados.
        </div>
    </div>

    <div class="card shadow mb-4 mt-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Lista de Cursos Disponíveis</h6>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered text-center" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Curso</th>
                            <th>Turno</th>
                            <th>Nível</th>
                            <th>Data de Início</th>
                            <th>Máx.Alunos</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any(curso => curso.Status == StatusCursoEnum.EmAndamento))
                        {
                            @foreach (var curso in Model.Where(c => c.Status == StatusCursoEnum.EmAndamento))
                            {
                                <tr>
                                    <td>@curso.Idioma</td>
                                    <td>@curso.Turno</td>
                                    <td>@curso.Nivel</td>
                                    <td>@curso.DataInicio.ToString("dd/MM/yyyy")</td>
                                    <td>@curso.MaxAlunos</td>
                                    <td>@curso.Status</td>
                                    <td>
                                        <form asp-controller="AlunoCurso" asp-action="AddAlunoAoCurso" method="post">
                                            <input type="hidden" name="AlunoId" value="@ViewBag.AlunoId" />
                                            <input type="hidden" name="CursoId" value="@curso.CursoId" />
                                            <button type="submit" class="btn-sm btn-primary">Adicionar Aluno</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center">Nenhum curso disponível</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
