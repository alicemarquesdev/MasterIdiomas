@using MasterIdiomas.Enums
@model AlunoModel
@{
    ViewData["Title"] = "Editar Dados - Aluno";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Editar Dados - Aluno</h1>
    
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-primary d-flex align-items-center" role="alert">
            <div>
                @TempData["MensagemSucesso"]
            </div>

            <button type="button" class="btn btn-primary btn-sm close-alert ms-auto" data-bs-dismiss="alert" aria-label="Close">X</button>

        </div>
    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <div>
                @TempData["MensagemErro"]
            </div>
            <button type="button" class="btn btn-danger btn-sm close-alert ms-auto" data-bs-dismiss="alert" aria-label="Close">X</button>

        </div>
    }

    <form asp-controller="Aluno" asp-action="AtualizarAluno" method="post">
        
        <input type="hidden" asp-for="AlunoId" />

        <!-- Nome -->
        <div class="mb-3">
            <label for="Nome" class="form-label">Nome</label>
            <input type="text" class="form-control" asp-for="Nome" maxlength="100">
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Nome)
            </span>
        </div>

        <!-- Data de Nascimento -->
        <div class="mb-3">
            <label for="DataNascimento" class="form-label">Data de Nascimento</label>
            <input type="date" class="form-control" asp-for="DataNascimento" min="1940-12-25" max="2010 -12-25">
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.DataNascimento)
            </span>
        </div>

        <!-- Gênero -->
        <div class="mb-3">
            <label for="Genero" class="form-label">Gênero</label>
            <select class="form-control" asp-for="Genero">
                <option value="" selected>Selecione</option>
                <option value="Feminino">Feminino</option>
                <option value="Masculino">Masculino</option>
                <option value="Outro">Outro</option>
            </select>
            <span class="text-danger">
                @Html.ValidationMessageFor(x => x.Genero)
            </span>
        </div>

        <!-- Botões -->
        <button type="submit" class="btn btn-primary w-100 mb-1">Editar Dados do Aluno</button>
        <a class="btn btn-secondary d-block" asp-action="Index" asp-controller="Aluno" role="button">Voltar</a>
    </form>
</div>
