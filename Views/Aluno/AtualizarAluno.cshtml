@using MasterIdiomas.Enums
@model AlunoModel

@{
    ViewData["Title"] = "Editar Dados - Aluno";
}

<div class="container-fluid px-4">
    <ol class="breadcrumb mt-1 bg-transparent">
        <li class="breadcrumb-item">
            <a asp-controller="Aluno" asp-action="Index" class="text-decoration-none">Alunos</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Editar Dados</li>
    </ol>

    <h1 class="mt-2 mb-4">Editar Dados - Aluno</h1>

    <form asp-controller="Aluno" asp-action="AtualizarAluno" method="post">
        <input type="hidden" asp-for="AlunoId" />

        <!-- Nome -->
        <div class="mb-3">
            <label for="Nome" class="form-label">Nome</label>
            <input type="text" class="form-control" asp-for="Nome" maxlength="100">
            <span class="text-danger">@Html.ValidationMessageFor(x => x.Nome)</span>
        </div>

        <!-- Data de Nascimento -->
        <div class="mb-3">
            <label for="DataNascimento" class="form-label">Data de Nascimento</label>
            <input type="date" class="form-control" asp-for="DataNascimento" min="1940-12-25" max="2020-12-25">
            <span class="text-danger">@Html.ValidationMessageFor(x => x.DataNascimento)</span>
        </div>

        <div class="mb-3">
            <label for="Genero" class="form-label">Gênero</label>
            <select class="form-control" asp-for="Genero">
                <option value="" selected>Selecione</option>
                <option value="@GeneroEnum.Feminino">@GeneroEnum.Feminino</option>
                <option value="@GeneroEnum.Masculino">@GeneroEnum.Masculino</option>
                <option value="@GeneroEnum.Outro">@GeneroEnum.Outro</option>
            </select>
            <span class="text-danger">@Html.ValidationMessageFor(x => x.Genero)</span>
        </div>

        <!-- Status -->
        <div class="mb-3">
            <label for="Status" class="form-label">Status</label>
            <select class="form-control" asp-for="Status">
                <option value="@StatusEnum.Ativo" selected>@StatusEnum.Ativo</option>
                <option value="@StatusEnum.Inativo">@StatusEnum.Inativo</option>
            </select>
            <span class="text-danger">@Html.ValidationMessageFor(x => x.Status)</span>
        </div>

        <!-- Botões -->
        <button type="submit" class="btn btn-primary w-100 mb-1">Editar Dados do Aluno</button>
        <a class="btn btn-secondary d-block" asp-action="Index" asp-controller="Aluno" role="button">Voltar</a>
    </form>
</div>
