@model List<CursoModel>
@{
    ViewData["Title"] = "Cursos do Aluno";
}

<div class="container-fluid px-4">
    <ol class="breadcrumb mt-1 bg-transparent">
        <li class="breadcrumb-item">
            <a asp-controller="Aluno" asp-action="Index" class="text-decoration-none">Alunos</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Cursos do Aluno</li>
    </ol>

    <h1 class="mt-2 mb-4">Cursos do Aluno</h1>

    <div class="card mb-3">
        <div class="card-body">
            Visualize e gerencie todos os cursos ativos ou concluídos pelo aluno em seu histórico acadêmico.
        </div>
    </div>

    <div class="card shadow mb-4 mt-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Cursos do Aluno</h6>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered text-center" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Idioma</th>
                            <th>Data de Início</th>
                            <th>Turno</th>
                            <th>Nível</th>
                            <th>Professor</th>
                            <th>Carga Horária</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var curso in Model)
                            {
                                <tr>
                                    <td>@curso.Idioma</td>
                                    <td>@curso.DataInicio.ToString("dd/MM/yyyy")</td>
                                    <td>@curso.Turno</td>
                                    <td>@curso.Nivel</td>
                                    <td>@(curso.Professor != null ? curso.Professor.Nome : "-")</td>
                                    <td>@curso.CargaHoraria</td>
                                    <td>@curso.Status</td>
                                    <td>
                                        <form asp-controller="AlunoCurso" asp-action="RemoverAlunoDoCurso" method="post">
                                            <input type="hidden" name="alunoId" value="@ViewBag.AlunoId" />
                                            <input type="hidden" name="cursoId" value="@curso.CursoId" />
                                            <button type="submit" class="btn-sm btn-danger">Remover Aluno</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center">Este aluno não está matriculado em nenhum curso.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
